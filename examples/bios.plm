/*  toy example: poke a value to memory-mapped "port" and call an
    external ROM routine via its absolute address                  */

DECLARE PORT   BYTE    AT (0F3H);         /* memory-mapped I/O port  */
DECLARE VRAM   BYTE(8) AT (8000H);        /* absolute-address array  */

BIOSOUT: PROCEDURE (CH) AT (0F803H);       /* external ROM routine    */
    DECLARE CH BYTE;
END BIOSOUT;

DECLARE I BYTE;

I = 0;
DO WHILE I < 8;
    VRAM(I) = I;
    I = I + 1;
END;

PORT = 42;
CALL BIOSOUT(65);
