/*  sum the first COUNT bytes of global BUF  */

DECLARE BUF BYTE(16) INITIAL(1, 2, 3, 4, 5, 6, 7, 8);
DECLARE N BYTE INITIAL(8);
DECLARE RESULT BYTE;

SUMBUF: PROCEDURE(COUNT) BYTE;
    DECLARE COUNT BYTE;
    DECLARE I BYTE;
    DECLARE ACC BYTE;
    ACC = 0;
    I = 0;
    DO WHILE I < COUNT;
        ACC = ACC + BUF(I);
        I = I + 1;
    END;
    RETURN ACC;
END SUMBUF;

RESULT = SUMBUF(N);
